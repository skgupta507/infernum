# ── DATABASE ─────────────────────────────────────────────────
# Neon PostgreSQL (recommended)
DATABASE_URL=postgresql://user:password@host.neon.tech/infernum?sslmode=require

# ── AUTH ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth (https://discord.com/developers)
# optional — leave blank to disable Discord login
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── REDIS ────────────────────────────────────────────────────
# Option A: Upstash (recommended for Vercel / serverless)
#   Create free at https://upstash.com → Redis → REST API
REDIS_URL=https://your-instance.upstash.io
REDIS_TOKEN=your-upstash-rest-token

# Option B: Standard Redis (Railway, Render, Fly.io, local)
#   Only REDIS_URL needed; ioredis is used automatically
# REDIS_URL=redis://default:password@your-host:6379

# Option C: Local dev (no Redis)
#   Leave both blank — INFERNUM runs fine without Redis

# ── API ──────────────────────────────────────────────────────
# The DramaCool/Consumet API backend URL
API_URL=https://api.consumet.org/movies/dramacool

# ── OPTIONAL ─────────────────────────────────────────────────
# Public app URL (used for OG images, absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:1999

# Slack webhook for watch-event notifications
SLACK_WEBHOOK_URL=

# Bearer token for /api/user/activity and /api/series/sync
API_SECRET_KEY=
