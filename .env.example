# ── DATABASE ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL (recommended for Vercel)
# Create free at https://neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/infernum?sslmode=require

# ── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Google OAuth  (https://console.cloud.google.com → APIs & Services → Credentials)
# Authorised redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth  (https://discord.com/developers/applications)
# Redirect URI: https://your-domain.com/api/auth/callback/discord
# Leave blank to disable Discord login
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── XYRA STREAM API ───────────────────────────────────────────────────────────
# Get your key at https://api.xyra.stream
XYRA_API_KEY=key1

# Override base URL if needed (default is already set in env.mjs)
# XYRA_API_URL=https://api.xyra.stream/v1/dramacool

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Option A: Upstash  (recommended — free tier at https://upstash.com)
#   Dashboard → Redis → REST API → copy URL and token
REDIS_URL=https://your-instance.upstash.io
REDIS_TOKEN=your-upstash-token

# Option B: Standard Redis  (Railway, Render, Fly.io, Docker)
#   pnpm add ioredis  is required for this option
# REDIS_URL=redis://default:password@your-host:6379

# Option C: Disabled
#   Leave REDIS_URL blank — INFERNUM runs fine without Redis

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Canonical URL — used for absolute links and OG images
